{
    "TinyPHP Class Entry": {
        "prefix": "class",
        "body": ["class ${1:Main}", "{", "\tpublic function main(): void", "\t{", "\t\t${0:echo \"hello\\n\";}", "\t}", "}"],
        "description": "TinyPHP class entry with main() method"
    },
    "Class extends": {
        "prefix": "classe",
        "body": ["class ${1:ClassName} extends ${2:ParentClass}", "{", "\t${0}", "}"],
        "description": "Class with extends"
    },
    "Class with constructor": {
        "prefix": "classc",
        "body": ["class ${1:ClassName}", "{", "\tpublic function __construct(${2})", "\t{", "\t\t${0}", "\t}", "}"],
        "description": "Class with constructor"
    },
    "Class with constructor promotion": {
        "prefix": "classcp",
        "body": ["class ${1:ClassName}", "{", "\tpublic function __construct(", "\t\tpublic ${2:int} \\$${3:prop}", "\t) {", "\t\t${0}", "\t}", "}"],
        "description": "Class with constructor promotion"
    },
    "Abstract class": {
        "prefix": "abstract",
        "body": ["abstract class ${1:ClassName}", "{", "\t${0}", "}"],
        "description": "Abstract class declaration"
    },
    "Interface": {
        "prefix": "interface",
        "body": ["interface ${1:InterfaceName}", "{", "\tpublic function ${2:method}(${3}): ${4:void};", "\t${0}", "}"],
        "description": "Interface declaration"
    },
    "Trait": {
        "prefix": "trait",
        "body": ["trait ${1:TraitName}", "{", "\tpublic function ${2:method}(): ${3:void}", "\t{", "\t\t${0}", "\t}", "}"],
        "description": "Trait declaration"
    },
    "Enum (string backing)": {
        "prefix": "enum",
        "body": ["enum ${1:Color}: ${2|string|string}", "{", "\tcase ${3:Red} = ${4:\"red\"};", "\tcase ${5:Green} = ${6:\"green\"};", "\tcase ${7:Blue} = ${8:\"blue\"};", "}"],
        "description": "Enum with string backing type"
    },
    "Enum (int backing)": {
        "prefix": "enumi",
        "body": ["enum ${1:Status}: int", "{", "\tcase ${2:Pending} = 0;", "\tcase ${3:Active} = 1;", "\tcase ${4:Deleted} = 2;", "}"],
        "description": "Enum with int backing type"
    },
    "Function": {
        "prefix": "function",
        "body": ["function ${1:name}(${2:params})${3:: ${4:returnType}}", "{", "\t${0}", "}"],
        "description": "Function declaration"
    },
    "Public method": {
        "prefix": "pubf",
        "body": ["public function ${1:name}(${2:params}): ${3:void}", "{", "\t${0}", "}"],
        "description": "Public method"
    },
    "Private method": {
        "prefix": "prif",
        "body": ["private function ${1:name}(${2:params}): ${3:void}", "{", "\t${0}", "}"],
        "description": "Private method"
    },
    "Static method": {
        "prefix": "statf",
        "body": ["public static function ${1:name}(${2:params}): ${3:void}", "{", "\t${0}", "}"],
        "description": "Static method"
    },
    "Arrow function": {
        "prefix": "fn",
        "body": "fn(\\$${1:x}) => ${0:expr}",
        "description": "Arrow function"
    },
    "Closure": {
        "prefix": "closure",
        "body": ["function (${1:params}) use (${2:vars})${3:: ${4:void}}", "{", "\t${0}", "}"],
        "description": "Closure with use"
    },
    "if": {
        "prefix": "if",
        "body": ["if (${1:condition}) {", "\t${0}", "}"],
        "description": "If statement"
    },
    "if-else": {
        "prefix": "ifelse",
        "body": ["if (${1:condition}) {", "\t${2}", "} else {", "\t${0}", "}"],
        "description": "If-else statement"
    },
    "if-elseif-else": {
        "prefix": "elseif",
        "body": ["if (${1:condition}) {", "\t${2}", "} elseif (${3:condition}) {", "\t${4}", "} else {", "\t${0}", "}"],
        "description": "If-elseif-else statement"
    },
    "for": {
        "prefix": "for",
        "body": ["for (\\$${1:i} = ${2:0}; \\$${1:i} < ${3:n}; \\$${1:i}++) {", "\t${0}", "}"],
        "description": "For loop"
    },
    "foreach": {
        "prefix": "foreach",
        "body": ["foreach (\\$${1:array} as \\$${2:key} => \\$${3:value}) {", "\t${0}", "}"],
        "description": "Foreach loop with key"
    },
    "foreach (value only)": {
        "prefix": "foreachv",
        "body": ["foreach (\\$${1:array} as \\$${2:value}) {", "\t${0}", "}"],
        "description": "Foreach loop (value only)"
    },
    "while": {
        "prefix": "while",
        "body": ["while (${1:condition}) {", "\t${0}", "}"],
        "description": "While loop"
    },
    "do-while": {
        "prefix": "dowhile",
        "body": ["do {", "\t${0}", "} while (${1:condition});"],
        "description": "Do-while loop"
    },
    "switch": {
        "prefix": "switch",
        "body": ["switch (${1:expr}) {", "\tcase ${2:value}:", "\t\t${3}", "\t\tbreak;", "\tdefault:", "\t\t${0}", "}"],
        "description": "Switch statement"
    },
    "match": {
        "prefix": "match",
        "body": ["match (${1:expr}) {", "\t${2:pattern} => ${3:result},", "\tdefault => ${0:defaultResult},", "}"],
        "description": "Match expression"
    },
    "try-catch": {
        "prefix": "try",
        "body": ["try {", "\t${1}", "} catch (${2:Exception} \\$${3:e}) {", "\t${0}", "}"],
        "description": "Try-catch"
    },
    "try-catch-finally": {
        "prefix": "trycf",
        "body": ["try {", "\t${1}", "} catch (${2:Exception} \\$${3:e}) {", "\t${4}", "} finally {", "\t${0}", "}"],
        "description": "Try-catch-finally"
    },
    "throw": {
        "prefix": "throw",
        "body": "throw new ${1:Exception}(\"${2:message}\");${0}",
        "description": "Throw exception"
    },
    "namespace": {
        "prefix": "ns",
        "body": ["namespace ${1:App\\\\Module};", "", "${0}"],
        "description": "Namespace declaration"
    },
    "use import": {
        "prefix": "use",
        "body": "use ${1:App\\\\ClassName};${0}",
        "description": "Use import"
    },
    "use group import": {
        "prefix": "usegroup",
        "body": "use ${1:App}\\\\{${2:ClassA}, ${3:ClassB}};${0}",
        "description": "Use group import"
    },
    "list destructure": {
        "prefix": "list",
        "body": "list(\\$${1:a}, \\$${2:b}) = \\$${0:array};",
        "description": "List destructure"
    },
    "array destructure": {
        "prefix": "arrlist",
        "body": "[\\$${1:a}, \\$${2:b}] = \\$${0:array};",
        "description": "Array destructure"
    },
    "echo": {
        "prefix": "echo",
        "body": "echo \\$${1:var};${0}",
        "description": "Echo variable"
    },
    "var_dump": {
        "prefix": "vd",
        "body": "var_dump(\\$${1:var});${0}",
        "description": "var_dump debug"
    },
    "array": {
        "prefix": "arr",
        "body": "[${1:items}]",
        "description": "Array literal"
    },
    "C call": {
        "prefix": "C",
        "body": "C->${1:func}(${0})",
        "description": "C interop call"
    },
    "c_int cast": {
        "prefix": "cint",
        "body": "c_int(${0:expr})",
        "description": "PHP to C int cast"
    },
    "c_float cast": {
        "prefix": "cfloat",
        "body": "c_float(${0:expr})",
        "description": "PHP to C float cast"
    },
    "c_str cast": {
        "prefix": "cstr",
        "body": "c_str(${0:expr})",
        "description": "PHP to C string cast"
    },
    "#include": {
        "prefix": "#include",
        "body": "#include ${1|,Windows ,Linux ,MacOS ,Darwin |}\"${2:file}\"",
        "description": "Preprocessor include (supports OS filter)"
    },
    "#include_angle": {
        "prefix": "#include<",
        "body": "#include ${1|,Windows ,Linux ,MacOS ,Darwin |}<${2:file}>",
        "description": "Preprocessor include with angle brackets (supports OS filter)"
    },
    "#callback": {
        "prefix": "#callback",
        "body": "#callback ${1:type} ${2:name}(${3:params})",
        "description": "Preprocessor callback"
    },
    "#flag": {
        "prefix": "#flag",
        "body": "#flag ${1|,GCC ,Clang ,TCC ,Windows ,Linux ,MacOS ,Darwin |}${2:-Dflag}",
        "description": "Preprocessor compiler/linker flag (supports OS/CC filter)"
    },
    "#import": {
        "prefix": "#import",
        "body": "#import ${1:module}",
        "description": "Preprocessor import"
    },
    "#debug": {
        "prefix": "#debug",
        "body": "#debug ${1:message}",
        "description": "Preprocessor debug"
    },
    "#cstruct": {
        "prefix": "#cstruct",
        "body": [
            "#cstruct ${1:Point} {",
            "\tC.${2:double} ${3:x};",
            "\tC.${4:double} ${5:y};",
            "}"
        ],
        "description": "C struct declaration (TinyPHP extension)"
    },
    "Property Hook (get/set)": {
        "prefix": "prophook",
        "body": [
            "public ${1:string} \\$${2:name} {",
            "\tget => ${3:strtoupper}(\\$this->${2:name});",
            "\tset => ${4:strtolower}(\\$value);",
            "}"
        ],
        "description": "Property Hook (PHP 8.4 + TinyPHP): compiled to getter/setter methods"
    },
    "Property Hook (block body)": {
        "prefix": "prophookb",
        "body": [
            "public ${1:string} \\$${2:name} {",
            "\tget {",
            "\t\treturn \\$this->${2:name};",
            "\t}",
            "\tset {",
            "\t\t\\$this->${2:name} = \\$value;",
            "\t}",
            "}"
        ],
        "description": "Property Hook with block body"
    },
    "Arrow function (block body)": {
        "prefix": "fnb",
        "body": "fn(\\$${1:x}): ${2:void} => {\\n\\t${0}\\n}",
        "description": "Arrow function with block body (TinyPHP extension, must end with return)"
    },
    "Arrow function (typed)": {
        "prefix": "fnt",
        "body": "fn(${1:int} \\$${2:x}): ${3:int} => ${0:expr}",
        "description": "Arrow function with typed params and return type (TinyPHP requires both)"
    },
    "Pipe operator": {
        "prefix": "pipe",
        "body": "\\$${1:x} |> ${2:f}(${0:...})",
        "description": "Pipe operator (TinyPHP extension, PHP 8.4 RFC). Use ... as placeholder"
    },
    "Pipe chain": {
        "prefix": "pipechain",
        "body": "\\$${1:x}\n\t|> ${2:f1}(...)\n\t|> ${3:f2}(...)",
        "description": "Chained pipe operators"
    },
    "Spread array": {
        "prefix": "spread",
        "body": "[...\\$${1:arr1}, ...\\$${2:arr2}]",
        "description": "Array spread/unpack (PHP 7.4+)"
    },
    "Generator function": {
        "prefix": "gen",
        "body": [
            "function ${1:gen}(${2:params}): Generator",
            "{",
            "\t${3:foreach (\\$${4:items} as \\$${5:item}) {",
            "\t\tyield \\$${5:item};",
            "\t}}",
            "\t${0:return ${6:null};}",
            "}"
        ],
        "description": "Generator function using yield (supported via minicoro)"
    },
    "yield value": {
        "prefix": "yield",
        "body": "yield ${0:value};",
        "description": "yield a value from generator"
    },
    "yield key => value": {
        "prefix": "yieldkv",
        "body": "yield ${1:key} => ${0:value};",
        "description": "yield key-value pair"
    },
    "yield from": {
        "prefix": "yieldfrom",
        "body": "yield from ${0:subgen};",
        "description": "yield from sub-generator or array"
    },
    "defer expression": {
        "prefix": "defer",
        "body": "defer ${1:C->free}(${2:\\$buf});",
        "description": "defer expression — Zig-style scope cleanup, expands at compile time to all return paths (LIFO order)"
    },
    "defer echo": {
        "prefix": "deferecho",
        "body": "defer echo ${0:\"done\\n\"};",
        "description": "defer echo — debug output at function exit"
    },
    "defer block": {
        "prefix": "deferblock",
        "body": [
            "defer {",
            "\t${1:// cleanup code}",
            "}"
        ],
        "description": "defer block — multi-statement cleanup, LIFO execution at function exit"
    },
    "Annotation declaration": {
        "prefix": "attrd",
        "body": [
            "#[Attribute(${1:name}: ${2:string})]",
            "const ${3:ROUTE} = [];"
        ],
        "description": "Annotation type declaration (TinyPHP extension)"
    },
    "Annotation usage": {
        "prefix": "attr",
        "body": "#[${1:ROUTE}(\"${2:/path}\")]",
        "description": "Annotation usage on class/method/function (positional args only)"
    },
    "Export attribute": {
        "prefix": "export",
        "body": "#[Export(\"${1:c_function_name}\")]\nfunction ${2:phpFunc}(${3:params}): ${4:retType}\n{\n\t${0}\n}",
        "description": "#[Export] attribute for DLL export (-shared mode)"
    },
    "Annotation call": {
        "prefix": "attrcall",
        "body": "${1:ROUTE}[0]->call(${0:args});",
        "description": "Call annotation target via AnnotationEntry->call()"
    },
    "Annotation newInstance": {
        "prefix": "attrnew",
        "body": "\\$${1:obj} = ${2:ROUTE}[0]->newInstance(${0:args});",
        "description": "Instantiate annotation class via AnnotationEntry->newInstance()"
    },
    "Static local variable": {
        "prefix": "staticvar",
        "body": "static ${1:int} \\$${2:counter} = ${3:0};",
        "description": "Static local variable declaration"
    },
    "Heredoc string": {
        "prefix": "heredoc",
        "body": [
            "<<<${1:EOT}",
            "${2:content with \\$var interpolation}",
            "${1:EOT};"
        ],
        "description": "Heredoc string (supports $var and {$obj->prop} interpolation)"
    },
    "Nowdoc string": {
        "prefix": "nowdoc",
        "body": [
            "<<<'${1:EOT}'",
            "${2:literal content no interpolation}",
            "${1:EOT};"
        ],
        "description": "Nowdoc string (no interpolation)"
    },
    "error() throw": {
        "prefix": "error",
        "body": "error(\"${1:message}\");${0}",
        "description": "error($msg) — equivalent to throw new Exception($msg)"
    },
    "Type|Exception return type": {
        "prefix": "throws",
        "body": ": ${1:int}|Exception",
        "description": "Type|Exception return type (required for functions containing throw/error())"
    },
    "c_void_ptr cast": {
        "prefix": "cvptr",
        "body": "c_void_ptr(${0:expr})",
        "description": "PHP to C void* passthrough"
    },
    "php_str_clone": {
        "prefix": "phpstrc",
        "body": "php_str_clone(${0:expr})",
        "description": "C char* to PHP string (deep copy)"
    },
    "phpc_auto (auto-managed C pointer)": {
        "prefix": "phpcauto",
        "body": "phpc_auto(${0:ptr})",
        "description": "Auto-register C pointer for automatic free on scope exit/exception"
    },
    "phpc_free": {
        "prefix": "phpcfree",
        "body": "phpc_free(${0:ptr})",
        "description": "Free C pointer + unregister + zero variable (prevents UAF)"
    },
    "phpc_assert_ptr": {
        "prefix": "phpcassert",
        "body": "phpc_assert_ptr(${0:ptr}, \"${1:name}\")",
        "description": "Assert pointer is non-NULL, else throw tp_throw"
    },
    "use function": {
        "prefix": "usefn",
        "body": "use function ${1:App\\\\Utils}\\\\${2:helper};${0}",
        "description": "use function import"
    },
    "use const": {
        "prefix": "useconst",
        "body": "use const ${1:App}\\\\${2:CONFIG};${0}",
        "description": "use const import"
    },
    "use function group": {
        "prefix": "usefngroup",
        "body": "use function ${1:App}\\\\Utils\\\\{${2:helper1}, ${3:helper2}};${0}",
        "description": "use function group import"
    },
    "Type cast": {
        "prefix": "cast",
        "body": "(${1:int}) ${0:expr}",
        "description": "Type cast: (int)/(float)/(string)/(bool)"
    },
    "C type cast": {
        "prefix": "ccast",
        "body": "(C.${1:int}) ${0:expr}",
        "description": "C type cast: (C.int), (C.void*), (C.Point*)"
    },
    "Type annotation (local var)": {
        "prefix": "vdecl",
        "body": "${1:int} \\$${2:var} = ${0:0};",
        "description": "Local variable with optional type annotation (TinyPHP)"
    },
    "Type annotation (global const)": {
        "prefix": "cdecl",
        "body": "const ${1:int} ${2:MAX} = ${0:100};",
        "description": "Global/namespace constant with optional type (auto-deduction if omitted)"
    },
    "Thread class": {
        "prefix": "thread",
        "body": [
            "Thread::create(function(): void {",
            "\t${0:// thread body}",
            "});"
        ],
        "description": "Create a new Thread (tinycthread wrapper, Thread-Local runtime)"
    },
    "Conditional #if": {
        "prefix": "#if",
        "body": [
            "#if ${1:Windows}",
            "\t${0:// 条件代码}",
            "#endif"
        ],
        "description": "条件编译块 #if ... #endif (GRAMMAR.md §11.1)"
    },
    "Conditional #if-#else": {
        "prefix": "#ifelse",
        "body": [
            "#if ${1:Windows}",
            "\t${2:// Windows 实现}",
            "#else",
            "\t${0:// 其他平台}",
            "#endif"
        ],
        "description": "条件编译块 #if ... #else ... #endif"
    },
    "Conditional #if-#elseif-#else": {
        "prefix": "#ifelif",
        "body": [
            "#if ${1:Windows}",
            "\t${2:// Windows}",
            "#elseif ${3:Linux}",
            "\t${4:// Linux}",
            "#else",
            "\t${0:// 其他}",
            "#endif"
        ],
        "description": "条件编译块 #if ... #elseif ... #else ... #endif"
    }
}

