{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "TinyPHP",
    "scopeName": "source.tinyphp",
    "fileTypes": ["tphp", "php", "inc"],
    "patterns": [
        { "include": "#php-tag" },
        { "include": "#preprocessor" },
        { "include": "#annotations" },
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#constants" },
        { "include": "#namespace-paths" },
        { "include": "#type-declarations" },
        { "include": "#c-interop" },
        { "include": "#operators" },
        { "include": "#keywords" },
        { "include": "#variables" },
        { "include": "#functions" },
        { "include": "#numbers" }
    ],
    "repository": {
        "php-tag": {
            "name": "meta.embedded.block.php",
            "begin": "<\\?(php|=)?",
            "end": "(\\?>)",
            "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.php" } },
            "endCaptures": { "0": { "name": "punctuation.section.embedded.end.php" } },
            "patterns": [
                { "include": "#preprocessor" },
                { "include": "#annotations" },
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#constants" },
                { "include": "#namespace-paths" },
                { "include": "#type-declarations" },
                { "include": "#c-interop" },
                { "include": "#operators" },
                { "include": "#keywords" },
                { "include": "#variables" },
                { "include": "#functions" },
                { "include": "#numbers" }
            ]
        },

        "preprocessor": {
            "patterns": [
                {
                    "comment": "#include [OS] \"file\"",
                    "name": "meta.preprocessor.include.tinyphp",
                    "match": "^\\s*(#include)\\s+(?:(\\w+)\\s+)?(\")([^\"]+)(\")",
                    "captures": {
                        "1": { "name": "keyword.control.import.tinyphp" },
                        "2": { "name": "support.type.platform-filter.tinyphp" },
                        "3": { "name": "punctuation.definition.string.begin.php" },
                        "4": { "name": "string.quoted.double.php" },
                        "5": { "name": "punctuation.definition.string.end.php" }
                    }
                },
                {
                    "comment": "#include [OS] <file>",
                    "name": "meta.preprocessor.include.tinyphp",
                    "match": "^\\s*(#include)\\s+(?:(\\w+)\\s+)?(<)([^>]+)(>)",
                    "captures": {
                        "1": { "name": "keyword.control.import.tinyphp" },
                        "2": { "name": "support.type.platform-filter.tinyphp" },
                        "3": { "name": "punctuation.definition.string.begin.php" },
                        "4": { "name": "string.quoted.other.php" },
                        "5": { "name": "punctuation.definition.string.end.php" }
                    }
                },
                {
                    "comment": "#flag [OS/CC] flags...",
                    "name": "meta.preprocessor.flag.tinyphp",
                    "match": "^\\s*(#flag)\\s+((?:GCC|Clang|TCC|Windows|Linux|MacOS|Darwin)?\\s*.*)$",
                    "captures": {
                        "1": { "name": "keyword.control.import.tinyphp" },
                        "2": { "name": "string.unquoted.flag-args.tinyphp" }
                    }
                },
                {
                    "comment": "#cstruct Name { fields }",
                    "name": "meta.preprocessor.cstruct.tinyphp",
                    "begin": "^\\s*(#cstruct)\\s+(\\w+)\\s*\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.import.tinyphp" },
                        "2": { "name": "entity.name.type.struct.tinyphp" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.section.cstruct.end.tinyphp" }
                    },
                    "patterns": [
                        { "include": "#cstruct-fields" }
                    ]
                },
                {
                    "comment": "#if / #elseif / #elif / #else / #endif — conditional compilation (GRAMMAR.md §11.1)",
                    "name": "meta.preprocessor.conditional.tinyphp",
                    "match": "^\\s*(#(?:if|elseif|elif|else|endif))\\b(.*)$",
                    "captures": {
                        "1": { "name": "keyword.control.import.tinyphp" },
                        "2": {
                            "patterns": [
                                {
                                    "name": "keyword.operator.logical.tinyphp",
                                    "match": "&&|\\|\\||!"
                                },
                                {
                                    "name": "constant.language.platform.tinyphp",
                                    "match": "\\b(Windows|Win|Linux|MacOS|Darwin|Mac|TCC|TinyC|GCC|Clang|x86_64|amd64|x64|aarch64|arm64|debug|prod)\\b"
                                },
                                {
                                    "name": "punctuation.parenthesis.tinyphp",
                                    "match": "[()]"
                                }
                            ]
                        }
                    }
                },
                {
                    "comment": "#callback / #import / #debug",
                    "name": "meta.preprocessor.tinyphp",
                    "match": "^\\s*(#(?:callback|import|debug))\\b.*$",
                    "captures": {
                        "1": { "name": "keyword.control.import.tinyphp" }
                    }
                }
            ]
        },

        "cstruct-fields": {
            "patterns": [
                {
                    "comment": "C type field: C.double x or StructName name",
                    "match": "(C\\.[A-Za-z_][A-Za-z0-9_]*\\**|[A-Za-z_][A-Za-z0-9_]*)\\s+(\\w+)\\s*(;)?",
                    "captures": {
                        "1": { "name": "storage.type.c.tinyphp" },
                        "2": { "name": "variable.other.property.tinyphp" },
                        "3": { "name": "punctuation.terminator.statement.php" }
                    }
                },
                { "include": "#comments" }
            ]
        },

        "annotations": {
            "patterns": [
                {
                    "comment": "#[Attribute(p: type)] const NAME = []; — annotation declaration",
                    "name": "meta.annotation.declaration.tinyphp",
                    "match": "^\\s*(#\\[Attribute)\\s*\\(([^)]*)\\)\\s*\\]\\s*(const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)\\s*(\\[\\s*\\])\\s*(;)",
                    "captures": {
                        "1": { "name": "entity.name.function.attribute.tinyphp" },
                        "2": { "name": "string.unquoted.annotation-params.tinyphp" },
                        "3": { "name": "storage.modifier.php" },
                        "4": { "name": "entity.name.constant.php" },
                        "5": { "name": "keyword.operator.assignment.php" },
                        "6": { "name": "constant.language.array.empty.php" },
                        "7": { "name": "punctuation.terminator.statement.php" }
                    }
                },
                {
                    "comment": "#[Export(\"name\")] — function export annotation (GRAMMAR.md §15)",
                    "name": "meta.annotation.export.tinyphp",
                    "match": "(#\\[)(Export)\\s*\\(\\s*(\")([^\"]+)(\")\\s*\\]",
                    "captures": {
                        "1": { "name": "punctuation.definition.annotation.begin.tinyphp" },
                        "2": { "name": "entity.name.type.attribute.tinyphp" },
                        "3": { "name": "punctuation.definition.string.begin.php" },
                        "4": { "name": "string.quoted.double.php" },
                        "5": { "name": "punctuation.definition.string.end.php" }
                    }
                },
                {
                    "comment": "#[Name(args)] or #[Name] — annotation usage on class/method/function",
                    "name": "meta.annotation.usage.tinyphp",
                    "match": "(#\\[)([A-Za-z_\\\\][A-Za-z0-9_\\\\]*)(?:\\s*\\(([^)]*)\\))?\\]",
                    "captures": {
                        "1": { "name": "punctuation.definition.annotation.begin.tinyphp" },
                        "2": { "name": "entity.name.type.attribute.tinyphp" },
                        "3": { "name": "string.unquoted.annotation-args.tinyphp" }
                    }
                }
            ]
        },

        "c-interop": {
            "patterns": [
                {
                    "name": "meta.c-interop-call.tinyphp",
                    "match": "\\bC\\s*(->)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
                    "captures": {
                        "1": { "name": "keyword.operator.arrow.tinyphp" },
                        "2": { "name": "entity.name.function.c.tinyphp" },
                        "3": { "name": "punctuation.definition.arguments.begin.tinyphp" }
                    }
                },
                {
                    "comment": "C->CONST (no parens) — direct C constant/enum/macro access",
                    "name": "meta.c-interop-const.tinyphp",
                    "match": "\\bC\\s*(->)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\b(?!\\s*\\()",
                    "captures": {
                        "1": { "name": "keyword.operator.arrow.tinyphp" },
                        "2": { "name": "support.constant.c.tinyphp" }
                    }
                },
                {
                    "comment": "C.Type — C type annotation (C.int, C.double, C.int32, C.void*, C.Point*)",
                    "name": "storage.type.c.tinyphp",
                    "match": "\\bC\\.([A-Za-z_][A-Za-z0-9_]*)(\\*+)?",
                    "captures": {
                        "1": { "name": "storage.type.c.name.tinyphp" },
                        "2": { "name": "keyword.operator.pointer.tinyphp" }
                    }
                },
                {
                    "comment": "(C.Type) cast — C type cast: (C.int)expr, (C.void*)ptr, (C.Point*)p",
                    "name": "meta.c-interop-cast.tinyphp",
                    "match": "\\(C\\.([A-Za-z_][A-Za-z0-9_]*)(\\*+)\\)",
                    "captures": {
                        "1": { "name": "storage.type.c.name.tinyphp" },
                        "2": { "name": "keyword.operator.pointer.tinyphp" }
                    }
                },
                {
                    "name": "support.function.c-interop.tinyphp",
                    "match": "\\b(phpc_arr_int|phpc_arr_dbl|phpc_arr_str|phpc_new_arr_int|phpc_new_arr_dbl|phpc_new_arr_str|phpc_new_arr|phpc_obj|phpc_new_obj|phpc_unregister_obj|phpc_obj_steal|phpc_fn|phpc_env|phpc_fn_i32|phpc_fn_i64|phpc_fn_f64|phpc_thunk|phpc_env_pin|phpc_env_unpin|phpc_free|phpc_free_str_arr|phpc_auto|phpc_assert_ptr|phpc_ptr_to_int|phpc_int_to_ptr)\\s*(?=\\()"
                },
                {
                    "name": "support.function.c-interop.tinyphp",
                    "match": "\\b(c_int|c_float|c_str|c_void_ptr|php_int|php_float|php_str|php_str_ptr|php_str_clone)\\s*(?=\\()"
                },
                {
                    "name": "storage.type.c.tinyphp",
                    "match": "\\b(c_int|c_float|c_str|c_bool|c_void|php_int|php_float|php_str|php_bool|php_str_ptr|php_str_clone|c_void_ptr)\\b(?!\\s*\\()"
                }
            ]
        },

        "comments": {
            "patterns": [
                {
                    "name": "comment.block.documentation.php",
                    "begin": "/\\*\\*(?!/)",
                    "end": "\\*/",
                    "beginCaptures": { "0": { "name": "punctuation.definition.comment.php" } },
                    "endCaptures": { "0": { "name": "punctuation.definition.comment.php" } },
                    "patterns": [{
                        "name": "keyword.other.documentation.phpdoc.php",
                        "match": "@(?:param|return|throws|var|see|link|method|property|deprecated|since|author|version|inheritdoc)\\b"
                    }]
                },
                {
                    "name": "comment.block.php",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "beginCaptures": { "0": { "name": "punctuation.definition.comment.php" } },
                    "endCaptures": { "0": { "name": "punctuation.definition.comment.php" } }
                },
                {
                    "name": "comment.line.double-slash.php",
                    "begin": "//",
                    "end": "$\\n?"
                },
                {
                    "name": "comment.line.number-sign.php",
                    "begin": "(?<!\\w)(?<![#a-zA-Z0-9_])(#)(?!(?:include|flag|callback|import|debug)\\b)",
                    "end": "$\\n?",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.comment.php" }
                    }
                }
            ]
        },

        "strings": {
            "patterns": [
                {
                    "comment": "HTML Nowdoc: <<<'HTML' ... HTML",
                    "name": "meta.embedded.block.html.php",
                    "begin": "(<<<)\\s*('HTML')\\s*$",
                    "end": "^(\\s*)(HTML)(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "contentName": "text.html.derivative",
                    "patterns": [{ "include": "text.html.derivative" }]
                },
                {
                    "comment": "CSS Nowdoc: <<<'CSS' ... CSS",
                    "name": "meta.embedded.block.css.php",
                    "begin": "(<<<)\\s*('CSS')\\s*$",
                    "end": "^(\\s*)(CSS)(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "contentName": "source.css",
                    "patterns": [{ "include": "source.css" }]
                },
                {
                    "comment": "JS Nowdoc: <<<'JS' or <<<'JAVASCRIPT'",
                    "name": "meta.embedded.block.js.php",
                    "begin": "(<<<)\\s*('(?:JS|JAVASCRIPT)')\\s*$",
                    "end": "^(\\s*)((?:JS|JAVASCRIPT))(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "contentName": "source.js",
                    "patterns": [{ "include": "source.js" }]
                },
                {
                    "comment": "HTML Heredoc: <<<HTML ... HTML",
                    "name": "meta.embedded.block.html.php",
                    "begin": "(<<<)\\s*(HTML)\\s*$",
                    "end": "^(\\s*)(HTML)(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "contentName": "text.html.derivative",
                    "patterns": [{ "include": "text.html.derivative" }]
                },
                {
                    "comment": "CSS Heredoc: <<<CSS ... CSS",
                    "name": "meta.embedded.block.css.php",
                    "begin": "(<<<)\\s*(CSS)\\s*$",
                    "end": "^(\\s*)(CSS)(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "contentName": "source.css",
                    "patterns": [{ "include": "source.css" }]
                },
                {
                    "comment": "JS Heredoc: <<<JS or <<<JAVASCRIPT",
                    "name": "meta.embedded.block.js.php",
                    "begin": "(<<<)\\s*((?:JS|JAVASCRIPT))\\s*$",
                    "end": "^(\\s*)((?:JS|JAVASCRIPT))(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "contentName": "source.js",
                    "patterns": [{ "include": "source.js" }]
                },
                {
                    "comment": "Generic Nowdoc: <<<'TAG' ... TAG",
                    "name": "string.unquoted.nowdoc.php",
                    "begin": "(<<<)\\s*'([A-Za-z_][A-Za-z0-9_]*)'\\s*$",
                    "end": "^(\\s*)(\\2)(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    }
                },
                {
                    "comment": "Generic Heredoc: <<<TAG ... TAG",
                    "name": "string.unquoted.heredoc.php",
                    "begin": "(<<<)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*$",
                    "end": "^(\\s*)(\\2)(?![A-Za-z0-9_])",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.string.begin.php" },
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "endCaptures": {
                        "2": { "name": "keyword.operator.heredoc-token.php" }
                    },
                    "patterns": [
                        { "name": "constant.character.escape.php", "match": "\\\\[nrtfve\\\\$]" },
                        { "name": "variable.other.php", "match": "\\$[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*" }
                    ]
                },
                {
                    "name": "string.quoted.double.php",
                    "begin": "\"",
                    "end": "\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.php" } },
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.php" } },
                    "patterns": [
                        { "name": "constant.character.escape.php", "match": "\\\\[nrtfve\\\\$\"]|\\\\x[0-9A-Fa-f]{1,2}|\\\\u\\{[0-9A-Fa-f]+\\}|\\\\[0-7]{1,3}" },
                        { "name": "variable.other.php", "match": "\\$[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*" }
                    ]
                },
                {
                    "name": "string.quoted.single.php",
                    "begin": "'",
                    "end": "'",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.php" } },
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.php" } },
                    "patterns": [
                        { "name": "constant.character.escape.php", "match": "\\\\'|\\\\\\\\" }
                    ]
                }
            ]
        },

        "constants": {
            "patterns": [
                {
                    "name": "constant.language.php",
                    "match": "\\b(true|false|null)\\b"
                },
                {
                    "name": "constant.language.php",
                    "match": "\\b(__LINE__|__FILE__|__DIR__|__CLASS__|__METHOD__|__FUNCTION__|__NAMESPACE__|DIRECTORY_SEPARATOR)\\b"
                },
                {
                    "comment": "Extension constants (Filter/Pcre/Zlib/Zip/Stream/OpenSSL/Calendar/Exif/Fileinfo/Iconv/Seek)",
                    "name": "support.constant.extension.tinyphp",
                    "match": "\\b(FILTER_(?:VALIDATE|SANITIZE|FLAG)_[A-Z_]+|PREG_(?:PATTERN_ORDER|SET_ORDER|SPLIT_NO_EMPTY|SPLIT_DELIM_CAPTURE|GREP_INVERT|NO_ERROR|INTERNAL_ERROR|BACKTRACK_LIMIT_ERROR|RECURSION_LIMIT_ERROR)|ZLIB_(?:ENCODING_[A-Z]+|NO_COMPRESSION|BEST_SPEED|BEST_COMPRESSION|DEFAULT_COMPRESSION|NO_FLUSH|PARTIAL_FLUSH|SYNC_FLUSH|FULL_FLUSH|FINISH|BLOCK|FILTERED|HUFFMAN_ONLY|RLE|FIXED|DEFAULT_STRATEGY|OK|STREAM_END|NEED_DICT|ERRNO|STREAM_ERROR|DATA_ERROR|MEM_ERROR|BUF_ERROR|VERSION_ERROR|VERSION|VERNUM)|FORCE_(?:GZIP|DEFLATE)|ZIP_(?:CREATE|EXCL|CHECKCONS|TRUNCATE|RDONLY|FL_[A-Z]+|CM_[A-Z]+)|STREAM_(?:SOCK_[A-Z]+|PF_[A-Z0-9]+|IPPROTO_[A-Z]+|CRYPTO_[A-Z_]+)|CAL_[A-Z_]+|IMAGETYPE_[A-Z_]+|EXIF_TYPE_[A-Z]+|FILEINFO_[A-Z_]+|ICONV_(?:IMPL|VERSION)|SEEK_(?:SET|CUR|END))\\b"
                }
            ]
        },

        "namespace-paths": {
            "comment": "Highlight namespace paths in use/namespace statements and fully-qualified names. Supports group use: use A\\B\\{C, D\\E, F as G}",
            "patterns": [
                {
                    "comment": "use function/const A\\B\\{f1, f2 as g}; — grouped function/const import",
                    "name": "meta.use.group.php",
                    "begin": "(?i)\\b(use)\\s+(function|const)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*(?:\\\\[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)*)\\\\\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "1": { "name": "keyword.import.use.php" },
                        "2": { "name": "storage.modifier.php" },
                        "3": { "name": "entity.name.type.namespace.php" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.import.bracket.end.php" }
                    },
                    "patterns": [
                        {
                            "comment": "member as alias",
                            "match": "\\b([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)\\s+(as)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)",
                            "captures": {
                                "1": { "name": "entity.name.function.php" },
                                "2": { "name": "keyword.import.use.php" },
                                "3": { "name": "entity.name.function.php" }
                            }
                        },
                        {
                            "comment": "plain member (function or const name)",
                            "match": "\\b([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)\\b",
                            "captures": {
                                "1": { "name": "entity.name.function.php" }
                            }
                        },
                        {
                            "include": "#comments"
                        }
                    ]
                },
                {
                    "comment": "use A\\B\\{C, D\\E, F as G}; — grouped class import",
                    "name": "meta.use.group.php",
                    "begin": "(?i)\\b(use)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*(?:\\\\[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)*)\\\\\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "1": { "name": "keyword.import.use.php" },
                        "2": { "name": "entity.name.type.namespace.php" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.import.bracket.end.php" }
                    },
                    "patterns": [
                        {
                            "comment": "function/const prefix inside group: 'function f' or 'const K'",
                            "match": "\\b(function|const)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)",
                            "captures": {
                                "1": { "name": "storage.modifier.php" },
                                "2": { "name": "entity.name.function.php" }
                            }
                        },
                        {
                            "comment": "ClassName as Alias",
                            "match": "\\b([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*(?:\\\\[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)*)\\s+(as)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)",
                            "captures": {
                                "1": { "name": "entity.name.type.class.php" },
                                "2": { "name": "keyword.import.use.php" },
                                "3": { "name": "entity.name.type.class.php" }
                            }
                        },
                        {
                            "comment": "plain ClassName (may contain namespace separator \\)",
                            "match": "\\b([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*(?:\\\\[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)*)\\b",
                            "captures": {
                                "1": { "name": "entity.name.type.class.php" }
                            }
                        },
                        {
                            "include": "#comments"
                        }
                    ]
                },
                {
                    "comment": "use function/const A\\B\\f as g; — non-group function/const import",
                    "match": "(?i)\\b(use)\\s+(function|const)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*(?:\\\\[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)*)(?:\\s+(as)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*))?",
                    "captures": {
                        "1": { "name": "keyword.import.use.php" },
                        "2": { "name": "storage.modifier.php" },
                        "3": { "name": "entity.name.type.namespace.php" },
                        "4": { "name": "keyword.import.use.php" },
                        "5": { "name": "entity.name.function.php" }
                    }
                },
                {
                    "comment": "use A\\B\\C [as D]; — plain class import with optional alias",
                    "match": "(?i)\\b(use)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*(?:\\\\[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)*)(?:\\s+(as)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*))?",
                    "captures": {
                        "1": { "name": "keyword.import.use.php" },
                        "2": { "name": "entity.name.type.namespace.php" },
                        "3": { "name": "keyword.import.use.php" },
                        "4": { "name": "entity.name.type.class.php" }
                    }
                },
                {
                    "comment": "namespace A\\B\\C; — namespace declaration",
                    "match": "(?i)\\b(namespace)\\s+([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*(?:\\\\[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)*)",
                    "captures": {
                        "1": { "name": "keyword.namespace.php" },
                        "2": { "name": "entity.name.type.namespace.php" }
                    }
                },
                {
                    "name": "punctuation.separator.namespace.php",
                    "match": "(?<=[a-zA-Z_])[\\\\](?=[a-zA-Z_])"
                }
            ]
        },
        "type-declarations": {
            "patterns": [
                {
                    "comment": "catch (Type $e) — exception type in catch clause (supports leading backslash)",
                    "match": "(?i)\\b(catch)\\s*\\(\\s*\\\\?([A-Za-z_\\x7f-\\xff][A-Za-z0-9_\\\\\\x7f-\\xff]*)",
                    "captures": {
                        "1": { "name": "keyword.control.exception.php" },
                        "2": { "name": "entity.name.type.class.php" }
                    }
                },
                {
                    "name": "entity.name.type.class.php",
                    "match": "(?<=\\b(class|interface|trait|enum|extends|implements|new|instanceof|throw\\s+new|,)\\s*)[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\\\\\x7f-\\xff]*"
                },
                {
                    "name": "entity.name.function.php",
                    "match": "(?<=\\bfunction\\s+)[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*"
                },
                {
                    "comment": "ClassName:: — class name before static access",
                    "match": "([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\\\\\x7f-\\xff]*)\\s*(?=::)",
                    "captures": {
                        "1": { "name": "entity.name.type.class.php" }
                    }
                },
                {
                    "comment": "->method( / ?->method( / ::method( — method call",
                    "match": "(?<=->|\\?->|::)\\s*([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.php" }
                    }
                },
                {
                    "comment": "->member / ?->member / ::member — property or constant access (without args)",
                    "match": "(?<=->|\\?->|::)\\s*([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)(?!\\s*\\()",
                    "captures": {
                        "1": { "name": "variable.other.property.php" }
                    }
                },
                {
                    "comment": "fn/function parameter type: Type $name",
                    "match": "(?<=[(,]\\s*)((?:int|float|string|bool|array|mixed|object|void|never|callable)|([A-Za-z_\\x7f-\\xff][A-Za-z0-9_\\\\\\x7f-\\xff]*))\\s+(\\$[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)",
                    "captures": {
                        "1": { "name": "entity.name.type.class.php" },
                        "3": { "name": "variable.other.php" }
                    }
                },
                {
                    "comment": "局部变量类型标记: int $x = 42; (TinyPHP 可选类型标记, GRAMMAR.md §7)。类型必须是大写开头的类名或内置类型小写关键字，避免误匹配 echo/return 等控制流关键字",
                    "match": "^\\s*((?:int|float|string|bool|array|mixed|object|void|never|callable)|(?:[A-Z_\\x7f-\\xff][A-Za-z0-9_\\\\\\x7f-\\xff]*))\\s+(\\$[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)",
                    "captures": {
                        "1": { "name": "entity.name.type.class.php" },
                        "2": { "name": "variable.other.php" }
                    }
                },
                {
                    "comment": "静态局部变量类型: static int $x = 0; (类型可选, GRAMMAR.md §7)",
                    "match": "\\b(static)\\s+((?:int|float|string|bool|array|mixed|object|callable)|(?:[A-Za-z_\\x7f-\\xff][A-Za-z0-9_\\\\\\x7f-\\xff]*))\\s+(\\$[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)",
                    "captures": {
                        "1": { "name": "storage.modifier.php" },
                        "2": { "name": "entity.name.type.class.php" },
                        "3": { "name": "variable.other.php" }
                    }
                },
                {
                    "comment": "fn/function return type: function foo(): Type",
                    "match": "(?<=:\\s*)([A-Za-z_\\x7f-\\xff][A-Za-z0-9_\\\\\\x7f-\\xff]*)(?=\\s*(?:\\{|;|\\n|$))",
                    "captures": {
                        "1": { "name": "entity.name.type.class.php" }
                    }
                },
                {
                    "comment": "typed property: public Type $prop — accepts built-in + custom class names",
                    "match": "\\b(public|private|protected|static|readonly)\\s+([A-Za-z_\\x7f-\\xff][A-Za-z0-9_\\\\\\x7f-\\xff]*)\\s+(\\$[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)",
                    "captures": {
                        "1": { "name": "storage.modifier.php" },
                        "2": { "name": "entity.name.type.class.php" },
                        "3": { "name": "variable.other.property.php" }
                    }
                },
                {
                    "comment": "const [type] NAME — typed class constant (built-in + custom class names)",
                    "match": "(?<=\\bconst\\s+)([A-Za-z_\\x7f-\\xff][A-Za-z0-9_\\\\\\x7f-\\xff]*)\\s+([A-Za-z_][A-Za-z0-9_]*)",
                    "captures": {
                        "1": { "name": "entity.name.type.class.php" },
                        "2": { "name": "entity.name.constant.php" }
                    }
                },
                {
                    "comment": "const NAME — untyped constant (warning in TinyPHP)",
                    "match": "(?<=\\bconst\\s+)[A-Z_][A-Z0-9_]*"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.php",
                    "match": "\\b(if|else|elseif|for|while|do|foreach|switch|case|default|break|continue|return|goto|match|defer)\\b"
                },
                {
                    "comment": "yield / yield from — Generator keywords (TinyPHP ✅ via minicoro)",
                    "name": "keyword.control.generator.php",
                    "match": "\\byield\\s+from\\b|\\byield\\b"
                },
                {
                    "comment": "Property Hook get/set (PHP 8.4, TinyPHP ✅) — only inside property hook block { get => ...; set => ...; }",
                    "name": "keyword.control.hook.php",
                    "match": "\\b(get|set)\\b(?=\\s*(?:=>|\\{))"
                },
                {
                    "name": "keyword.control.exception.php",
                    "match": "\\b(try|catch|finally|throw)\\b"
                },
                {
                    "name": "keyword.other.php",
                    "match": "\\b(new|clone|instanceof|use|as|namespace|echo|print|global|unset|exit|die|list|and|or|xor|parent|self)\\b"
                },
                {
                    "name": "storage.modifier.php",
                    "match": "\\b(public|private|protected|static|final|abstract|readonly|const)\\b"
                },
                {
                    "name": "storage.type.class.php",
                    "match": "\\b(class|interface|trait|enum|extends|implements)\\b"
                },
                {
                    "name": "storage.type.function.php",
                    "match": "\\b(function|fn)\\b"
                },
                {
                    "name": "keyword.other.type.php",
                    "match": "\\b(int|float|string|bool|void|never|mixed|array|object|callable|iterable)\\b"
                },
                {
                    "name": "support.function.construct.php",
                    "match": "\\b(__construct|__destruct)\\b"
                },
                {
                    "name": "support.function.builtin.tinyphp",
                    "match": "\\b(var_dump|print_r|count|isset|empty|unset|error|exit|die|time|date|sleep|usleep|hrtime|microtime|mktime|strtotime|uniqid|is_int|is_float|is_string|is_bool|is_array|is_object|is_null|is_callable|is_resource|is_numeric|gettype|getenv|putenv|intval|floatval|strval|boolval|abs|round|ceil|floor|sqrt|pow|pi|fmod|deg2rad|rad2deg|intdiv|sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|exp|log|log10|is_finite|is_infinite|is_nan|rand|mt_rand|random_int|random_bytes|preg_match|preg_match_all|preg_replace|preg_split|preg_grep|preg_quote|preg_last_error|preg_last_error_msg|iconv|iconv_strlen|iconv_strpos|iconv_substr|iconv_get_encoding|iconv_set_encoding|iconv_mime_encode|iconv_mime_decode|filter_var|filter_list|filter_id|password_hash|password_verify|pcntl_fork|pcntl_wait|pcntl_waitpid|pcntl_exec|pcntl_alarm|pcntl_get_last_error|pcntl_strerror|posix_getpid|posix_getppid|posix_getuid|posix_geteuid|posix_getgid|posix_getegid|posix_getcwd|posix_isatty|posix_kill|posix_strerror|posix_get_last_error|posix_ttyname|posix_uname|posix_times|exif_imagetype|exif_read_data|exif_thumbnail|exif_tagname|exif_make_test_jpeg|exif_make_test_jpeg_ex|exif_make_test_tiff|exif_make_test_header|gregoriantojd|jdtogregorian|juliantojd|jdtojulian|jewishtojd|jdtojewish|jdtojewish_str|jewish_month_name|frenchtojd|jdtofrench|cal_days_in_month|cal_from_jd|cal_to_jd|cal_info|easter_date|easter_days|finfo_open|finfo_file|finfo_buffer|finfo_close|finfo_set_flags|mime_content_type|gzcompress|gzuncompress|gzencode|gzdecode|gzdeflate|gzinflate|zlib_encode|zlib_decode|gzopen|gzclose|gzread|gzwrite|gzputs|gzeof|gzgets|gzgetc|gzrewind|gzseek|gztell|gzpassthru|gzflush|gzfile|readgzfile|deflate_init|deflate_add|inflate_init|inflate_add|inflate_get_status|inflate_get_read_len|zip_open|zip_close|zip_num_files|zip_get_error_string|zip_locate|zip_read|zip_stat|zip_entry_name|zip_entry_filesize|zip_entry_compressedsize|zip_entry_compressionmethod|zip_entry_open|zip_entry_read|zip_entry_close|zip_add_file|zip_add_dir|zip_delete|zip_rename|stream_close|stream_last_error|stream_strerror|stream_set_blocking|stream_set_read_buffer|stream_set_write_buffer|stream_set_timeout|stream_isatty|stream_select|stream_get_contents|stream_get_line|stream_get_meta_data|stream_socket_server|stream_socket_accept|stream_socket_client|stream_socket_recvfrom|stream_socket_sendto|stream_socket_get_name|stream_socket_shutdown|stream_socket_enable_crypto|stream_socket_pair|openssl_ctx_new|openssl_ctx_free|openssl_ctx_use_certificate_file|openssl_ctx_use_private_key_file|openssl_ctx_set_verify|openssl_ctx_set_options|openssl_ssl_new|openssl_ssl_free|openssl_ssl_set_fd|openssl_ssl_connect|openssl_ssl_accept|openssl_ssl_read|openssl_ssl_write|openssl_ssl_shutdown|openssl_ssl_get_cipher_name|openssl_ssl_get_version|openssl_error_string|openssl_encrypt|openssl_decrypt|openssl_random_pseudo_bytes|openssl_digest|strtr2)\\b"
                },
                {
                    "comment": "TinyPHP built-in classes: Generator / Thread / Mutex / etc.",
                    "name": "support.class.builtin.tinyphp",
                    "match": "\\b(Generator|Thread|Mutex|CondVar|WaitGroup|Parallel|Resource|File|Exception)\\b"
                }
            ]
        },

        "variables": {
            "patterns": [
                {
                    "name": "variable.other.php",
                    "match": "\\$[a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*"
                },
                {
                    "name": "variable.language.this.php",
                    "match": "\\$this\\b"
                }
            ]
        },

        "inline": {
            "comment": "Patterns used inside function call parentheses (supports nested calls)",
            "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#constants" },
                { "include": "#namespace-paths" },
                { "include": "#c-interop" },
                { "include": "#functions" },
                { "include": "#variables" },
                { "include": "#numbers" },
                { "include": "#keywords" },
                { "include": "#type-declarations" },
                { "include": "#operators" }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function-call.php",
                    "begin": "([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)\\s*(\\()",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": { "name": "entity.name.function.php" },
                        "2": { "name": "punctuation.definition.arguments.begin.php" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.arguments.end.php" }
                    },
                    "patterns": [{ "include": "#inline" }]
                }
            ]
        },

        "operators": {
            "comment": "Type casting, reference params, labels",
            "patterns": [
                {
                    "comment": "(int)/(float)/(string)/(bool) type cast",
                    "match": "\\((int|float|string|bool)\\)",
                    "captures": {
                        "1": { "name": "keyword.other.type.php" }
                    }
                },
                {
                    "comment": "Pipe operator |> (TinyPHP extension, PHP 8.4 RFC)",
                    "match": "\\|>",
                    "name": "keyword.operator.pipe.tinyphp"
                },
                {
                    "comment": "nullsafe arrow ?->",
                    "match": "\\?->",
                    "name": "keyword.operator.nullsafe.tinyphp"
                },
                {
                    "comment": "spread operator ... (array unpacking)",
                    "match": "\\.\\.\\.",
                    "name": "keyword.operator.spread.tinyphp"
                },
                {
                    "comment": "reference param: int &$var",
                    "match": "(?<=[\\s(,])&(?=\\$[a-zA-Z_])",
                    "name": "keyword.operator.reference.php"
                },
                {
                    "comment": "label for goto: IDENTIFIER: (excludes control-flow keywords like default:/case:/else:)",
                    "match": "^\\s*(?!default\\s*:|case\\s*:|else\\s*:)([a-zA-Z_\\x7f-\\xff][a-zA-Z0-9_\\x7f-\\xff]*)\\s*:(?!:)",
                    "captures": {
                        "1": { "name": "entity.name.label.php" }
                    }
                },
                {
                    "comment": "compound assignment: += -= *= /= .= %= &= |= ^= <<= >>= **= ??=",
                    "match": "\\+=|-=|\\*=|/=|\\.=|%=|&=|\\|=|\\^=|<<=|>>=|\\*\\*=|\\?\\?=",
                    "name": "keyword.operator.assignment.php"
                },
                {
                    "comment": "comparison <=> spaceship",
                    "match": "<=>",
                    "name": "keyword.operator.comparison.php"
                },
                {
                    "comment": "coalesce ??",
                    "match": "\\?\\?",
                    "name": "keyword.operator.coalesce.php"
                },
                {
                    "comment": "power **",
                    "match": "\\*\\*",
                    "name": "keyword.operator.arithmetic.php"
                }
            ]
        },
        "numbers": {
            "patterns": [
                { "comment": "Float with optional underscores: 3_14.15_92, 1e10, 1.5E-3",
                  "name": "constant.numeric.float.php",
                  "match": "\\b([0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?|[0-9][0-9_]*[eE][+-]?[0-9]+)\\b" },
                { "comment": "Hex: 0x1F, 0xFF_FF (underscores allowed)",
                  "name": "constant.numeric.hex.php",
                  "match": "\\b0[xX][0-9a-fA-F_]+\\b" },
                { "comment": "Binary: 0b1010, 0b1010_1010",
                  "name": "constant.numeric.binary.php",
                  "match": "\\b0[bB][01_]+\\b" },
                { "comment": "Octal: 0o777 (TinyPHP extension, PHP 8.1+)",
                  "name": "constant.numeric.octal.php",
                  "match": "\\b0[oO][0-7_]+\\b" },
                { "comment": "Decimal with underscores: 1_000_000",
                  "name": "constant.numeric.decimal.php",
                  "match": "\\b([1-9][0-9_]*)\\b" },
                { "name": "constant.numeric.php", "match": "\\b0\\b" }
            ]
        }
    }
}
